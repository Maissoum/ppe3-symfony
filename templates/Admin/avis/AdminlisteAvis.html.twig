{% extends 'base.html.twig' %}

{% block title %}Liste des avis{% endblock %}

{% block body %}
<h1 class="text-center pt-3">📝 Liste des avis</h1>
<hr>

{{ form_start(formFiltreAvis) }}
<div class="row g-2 mb-3">
    <div class="col-md-6">
        {{ form_row(formFiltreAvis.flm) }}
    </div>
    <div class="col-md-3">
        {{ form_row(formFiltreAvis.note) }}
    </div>
    <div class="col-md-3 d-flex align-items-end">
        <button type="submit" class="btn btn-primary w-100">Rechercher</button>
    </div>
</div>
{{ form_end(formFiltreAvis) }}


<hr>

<div class="container mt-4">

    {# Affichage des messages flash #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="mb-3 text-end">
        <a href="{{ path('admin_avis_ajout') }}" class="btn btn-success">➕ Ajouter un avis</a>
    </div>

    {% if lesaviss|length > 0 %}
        <div class="table-responsive">
            <table class="table table-striped table-hover table-bordered align-middle text-center">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">Film</th>
                        <th scope="col">Note</th>
                        <th scope="col">Commentaire</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for avis in lesaviss %}
                        <tr>
                            <td>
                                {% if avis.flms %}
                                    <a href="{{ path('fichefilm', {'id': avis.flms.id}) }}">
                                        {{ avis.flms.titre }}
                                    </a>
                                {% else %}
                                    <em>Film supprimé</em>
                                {% endif %}
                            </td>
                            <td>
                                {% if avis.note <= 4 %}
                                    <span class="badge bg-danger text-white">{{ avis.note }}/10</span>
                                {% elseif avis.note <= 7 %}
                                    <span class="badge bg-warning text-dark">{{ avis.note }}/10</span>
                                {% else %}
                                    <span class="badge bg-success text-white">{{ avis.note }}/10</span>
                                {% endif %}
                            </td>
                            <td class="text-start">{{ avis.commentaire }}</td>
                            <td>
                                <a href="{{ path('admin_avis_modif', {'id': avis.id}) }}" class="btn btn-primary btn-sm mb-1">✏️ Modifier</a>
                                <a href="{{ path('admin_avis_supp', {'id': avis.id}) }}" class="btn btn-danger btn-sm mb-1" onclick="return confirm('Voulez-vous vraiment supprimer cet avis ?')">🗑 Supprimer</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <p class="text-center"><em>Aucun avis trouvé.</em></p>
    {% endif %}
</div>
{% endblock %}
