{% extends 'base.html.twig' %}

{% block title %}Gestion des Films{% endblock %}

{% block body %}
<h1 class="pt-2 text-center">🎬 Gestion des films</h1>
<a href="{{ path('admin_film_ajout') }}" class="btn btn-info mb-3">Ajouter un film</a>

<hr>
{{ form_start (formFiltreFilm) }}
{{ form_row (formFiltreFilm.titre) }}

<hr>
<button type="submit" class="btn btn-primary mb-3">Rechercher</button>
{{ form_end (formFiltreFilm) }}

{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label }} text-center font-weight-bold">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

<hr>

<table class="table table-hover table-striped">
    <thead class="thead-dark">
        <tr>
            <th scope="col">Titre</th>
            <th scope="col">Année</th>
            <th scope="col">Durée</th>
            <th scope="col">Image</th>
            <th scope="col">Catégories</th>
            <th scope="col">Action</th>
        </tr>
    </thead>
    <tbody>
        {% for film in lesFilms %}
            <tr>
                <td>{{ film.titre }}</td>
                <td>{{ film.dateSorti }}</td>
                <td>{{ film.duree }} min</td>
                <td>
                    {% if film.image %}
                        <span class="badge badge-info">{{ film.image }}</span>
                    {% else %}
                        <span class="badge badge-secondary">Aucune</span>
                    {% endif %}
                </td>
                <td>
                    {% for cat in film.cats %}
                        <span class="badge" style="background-color: {{ cat.couleur }}; color: white;">
                            {{ cat.nom }}
                        </span>
                    {% else %}
                        <span class="badge badge-secondary">Aucune</span>
                    {% endfor %}
                </td>
                <td>
                    <a href="{{ path('admin_film_modif', {'id': film.id}) }}" class="btn btn-primary">
                        <i class="fa-regular fa-pen-to-square"></i> Modifier
                    </a>

                    <a href="{{ path('admin_film_supp', {'id': film.id}) }}" class="btn btn-danger"
                       onclick="return confirm('Etes-vous sûr de vouloir supprimer le film : {{ film.titre }} ?');">
                        <i class="far fa-trash-alt"></i> Supprimer
                    </a>
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}