{% extends 'base.html.twig' %}

{% block stylesheets %}
<style>
    .form-card {
        max-width: 600px;
        margin: 50px auto;
        padding: 30px;
        border-radius: 15px;
        background-color: #fdf6e3; /* pastel clair neutre */
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        color: #333333;
    }

    .form-card h2 {
        text-align: center;
        margin-bottom: 25px;
        font-weight: bold;
        color: #333333;
    }

    .form-control {
        border-radius: 10px;
        margin-bottom: 15px;
    }

    .btn-submit {
        border-radius: 10px;
        font-weight: bold;
    }

    label {
        font-weight: bold;
    }

    .flash-message {
        max-width: 600px;
        margin: 20px auto;
    }
</style>
{% endblock %}

{% block title %}Ajout / Modification Catégorie{% endblock %}

{% block body %}

<div class="flash-message">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="close" data-dismiss="alert" aria-label="Fermer">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        {% endfor %}
    {% endfor %}
</div>

<div class="form-card">
    <h2>
        {% if app.request.attributes.get('_route') == 'admin_categorie_ajout' %}
            <i class="fas fa-plus-circle"></i> Ajouter une Catégorie
        {% else %}
            <i class="fas fa-edit"></i> Modifier la Catégorie
        {% endif %}
    </h2>

    {{ form_start(formCat, {'attr': {'novalidate':'novalidate'}}) }}

    <div class="form-group">
        {{ form_label(formCat.nom) }}
        {{ form_widget(formCat.nom, {'attr': {'class': 'form-control', 'placeholder':'Nom de la catégorie'}}) }}
    </div>

    <div class="form-group">
        {{ form_label(formCat.description) }}
        {{ form_widget(formCat.description, {'attr': {'class': 'form-control', 'placeholder':'Description de la catégorie'}}) }}
    </div>

    <div class="form-group">
        {{ form_label(formCat.couleur) }}
        {{ form_widget(formCat.couleur, {'attr': {'class': 'form-control', 'type':'color'}}) }}
    </div>

    <div class="d-flex justify-content-between mt-4">
        <input type="submit" class="btn btn-primary btn-submit" 
               value="{% if app.request.attributes.get('_route') == 'admin_categorie_ajout' %}Ajouter{% else %}Modifier{% endif %}">
        <a href="{{ path('admin_categorie_liste') }}" class="btn btn-secondary btn-submit">Annuler</a>
    </div>

    {{ form_end(formCat) }}
</div>

{% endblock %}

{% block javascripts %}
<script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
{% endblock %}
