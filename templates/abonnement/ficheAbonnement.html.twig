{% extends 'base.html.twig' %}

{% block title %}Fiche Abonnement{% endblock %}

{% block body %}
<div class="container py-5">

    <a href="{{ path('abonnement') }}" class="btn btn-outline-secondary mb-4">← Retour à la liste des abonnements</a>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg p-4" style="border-radius: 15px; background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%); color: white;">
                <div class="card-body text-center">
                    <h2 class="card-title mb-3" style="font-weight: bold;">{{ leabonnement.nom }}</h2>

                    <p class="card-text mb-2" style="font-size: 1.1em;">
                        <strong>Prix :</strong> {{ leabonnement.prix }} €
                    </p>

                    <p class="card-text mb-2" style="font-size: 1.1em;">
                        <strong>Durée :</strong> {{ leabonnement.duree }} jours
                    </p>

                    <p class="card-text mt-3" style="font-size: 1em; line-height: 1.5;">
                        {{ leabonnement.description }}
                    </p>

                    <a href="{{ path('abonnement') }}" class="btn btn-light mt-4" style="font-weight: bold;">S'abonner</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
