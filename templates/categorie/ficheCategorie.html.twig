{% extends 'base.html.twig' %}

{% block title %}Fiche catégorie{% endblock %}

{% block body %}
<h1 class="text-center pt-3">📁 Fiche de la catégorie</h1>
<hr>
<div class="mb-4 text-center">
        <a href="{{ path('film') }}" class="btn btn-secondary">
            ← Retour à la liste des Categories
        </a>
    </div>
<div class="container">

    <div class="card shadow-lg p-4 mb-4" style="border-radius: 15px;">

        <h2 class="text-center mb-3">
            <span class="badge"
                style="background-color: {{ lecat.couleur }}; color: white; font-size: 1.2em;">
                {{ lecat.nom }}
            </span>
        </h2>

        <p class="text-center" style="font-size:1.1em;">
            {{ lecat.description }}
        </p>

    </div>

    <div class="card shadow p-3" style="border-radius: 12px;">
        <h3 class="text-center mb-3">🎬 Films associés</h3>

        {% if lecat.films|length > 0 %}
            <table class="table table-hover align-middle text-center">
                <thead class="table-dark">
                    <tr>
                        <th>Titre</th>
                        <th>Sortie</th>
                        <th>Durée</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                {% for film in lecat.films %}
                    <tr>
                        <td>{{ film.titre }}</td>
                        <td>{{ film.dateSorti }}</td>
                        <td>{{ film.duree }} min</td>

                        <td>
                            <a href="{{ path('fichefilm', {'id': film.id}) }}"
                               class="btn btn-sm btn-primary">
                                Voir le film
                            </a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>

        {% else %}
            <p class="text-center"><em>Aucun film dans cette catégorie.</em></p>
        {% endif %}
    </div>

</div>

{% endblock %}
