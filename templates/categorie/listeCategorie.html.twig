{% extends 'base.html.twig' %}

{% block title %}Liste des catégories{% endblock %}

{% block body %}
<h1 class="text-center pt-3">🔖 Liste des catégories</h1>
<hr>

<div class="container mt-4">
    <div class="row">

        {% for cat in lescats %}
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm" style="border-radius: 12px;">
                    <div class="card-body text-center">

                        <span class="badge mb-2"
                              style="background-color: {{ cat.couleur }}; font-size:1em; color:white;">
                            {{ cat.nom }}
                        </span>

                        <p class="mt-2">{{ cat.description }}</p>

                        <a href="{{ path('fichecategorie', {'id': cat.id}) }}"
                           class="btn btn-primary mt-2">
                            Voir la catégorie
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <p class="text-center">Aucune catégorie trouvée.</p>
        {% endfor %}

    </div>
</div>

{% endblock %}
