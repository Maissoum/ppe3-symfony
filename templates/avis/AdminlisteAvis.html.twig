{% extends 'base.html.twig' %}
{# tidjani #}
{% block title %}Gestion des Avis{% endblock %}

{% block body %}
<h1 class="pt-2 text-center">📝 Gestion des Avis</h1>
<a href="{{ path('admin_avis_ajout') }}" class="btn btn-info mb-3">Ajouter un avis</a>

<div class="table-responsive">
    <table class="table table-hover table-striped table-bordered text-center align-middle">
        <thead class="table-dark">
            <tr>
                <th>Film</th>
                <th>Note</th>
                <th>Commentaire</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for avis in lesAvis %}
            <tr>
                <td><a href="{{ path('fichefilm', {'id': avis.flms.id}) }}">{{ avis.flms.titre }}</a></td>
                <td><span class="badge bg-warning text-dark">{{ avis.note }}/10</span></td>
                <td class="text-start">{{ avis.commentaire }}</td>
                <td>
                    <a href="{{ path('admin_avis_modif', {'id': avis.id}) }}" class="btn btn-primary"><i class="fas fa-pen"></i></a>
                    <a href="{{ path('admin_avis_supp', {'id': avis.id}) }}" class="btn btn-danger"><i class="fas fa-trash"></i></a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4"><em>Aucun avis trouvé.</em></td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
