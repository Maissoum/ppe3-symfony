<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}MatStream {% endblock %}</title>
         <link rel="stylesheet" href="https://bootswatch.com/4/slate/bootstrap.min.css">
         <link rel="stylesheet" href="{{asset('css/app.css')}}">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">
        {# Run `composer require symfony/webpack-encore-bundle` to start using Symfony UX #}
        <link rel="stylesheet" href="style.css">
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

       
    </head>
    <body>
       
     <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <a class="navbar-brand" href="{{path('accueil')}}">MattStream</a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarColor02" aria-controls="navbarColor02" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarColor02">
            <ul class="navbar-nav mr-auto">
               <li class="nav-item ">
                            <a class="nav-link" href="{{path('film')}}">liste des films</a>
                    </li>

                <li class="nav-item ">
                            <a class="nav-link" href="{{path('categorie')}}">liste des categories</a>                        
                    </li>
                  <li class="nav-item ">
                            <a class="nav-link" href="{{path('avis')}}">Tous vos avis</a>
                    </li>
                  <li class="nav-item ">
                            <a class="nav-link" href="{{path('abonnement')}}">Nos abonnement</a>
                    </li>


    {% if app.user and is_granted('ROLE_ADMIN') %}

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" data-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false">Administrateur</a>
                        <div class="dropdown-menu">
                            <a class="dropdown-item" href="{{path('admin_categorie_liste')}}">Gestion des catégories</a>
                            <a class="dropdown-item" href="{{ path('admin_film_liste') }}">Gestion des films</a>
                            <a class="dropdown-item" href="{{path('admin_avis_liste')}}">Gestion des avis</a>
                        </div>
                    </li>
    {% endif %}     

            </ul>

             <ul class="navbar-nav my-auto">


            {% if app.user %}
              <li class="nav-item">
                    <img class="avatar supermini" src="{{app.user.avatar}}" alt="photo de {{app.user.fullName}}">
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" data-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false">{{app.user.fullName}}</a>
                    <div class="dropdown-menu dropdown-menu-right">
                        <a class="dropdown-item" href="#">Mon profil</a>
                        <div class="dropdown-divider"></div>
                        <a class="dropdown-item" href="{{path('app_logout')}}">Se déconnecter</a>
                    </div>
                </li>
        
            {% else %}
                <li class="nav-item">
                    <a href="{{path('login')}}" class="nav-link">Se connecter</a>                
                </li>
                <li class="nav-item">
                    <a href="{{path('app_register')}}" class="nav-link">S'inscrire</a>                
                </li>
              
            {% endif %}

        </div>
        </nav>
         
         <div class ="container">
         {% block body %} {% endblock %}
         </div>

         
         
         
        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
            <script src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.slim.min.js" integrity="sha384-DfXdz2htPH0lsSSs5nCTpuj/zy4C+OGpamoFVy38MVBnE+IbbVYUew+OrCXaRkfj" crossorigin="anonymous"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-Fy6S3B9q64WdZWQUiU+q4/2Lc9npb8tCaSX9FK7E8HnRr0Jz8D6OP9dO5Vg3Q9ct" crossorigin="anonymous"></script>
 {% endblock %}
        
    </body>
</html>
